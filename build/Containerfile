# Build environment for the rollingWRT OpenWrt buildroot.
# Mirrors what CI runs (Debian userspace), keeps the heavy build off the host.
FROM docker.io/library/debian:trixie

RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential clang flex bison g++ gawk \
      gcc-multilib g++-multilib gettext git \
      libncurses-dev libssl-dev python3 python3-setuptools python3-venv \
      python3-jinja2 python3-pyelftools meson ninja-build \
      rsync unzip zlib1g-dev file wget swig time zstd \
      ca-certificates libelf-dev locales sudo gperf \
      xorriso mtools grub-common grub-pc-bin grub-efi-amd64-bin \
 && sed -i 's/^# *\(en_US.UTF-8\)/\1/' /etc/locale.gen && locale-gen \
 && rm -rf /var/lib/apt/lists/*

# OpenWrt refuses to build as root; build as an unprivileged user whose uid maps
# to the host user under rootless podman.
RUN useradd -m -s /bin/bash builder
USER builder
ENV LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 FORCE_UNSAFE_CONFIGURE=0
WORKDIR /work
