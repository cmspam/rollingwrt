config incus-ui-proxy 'main'
	option enabled '1'
	# HTTPS port the Incus web UI is reached on. Kept off 8443 on purpose:
	# incus's own remote API (core.https_address) conventionally uses 8443, so
	# the proxy would clash with it whenever a user enables that. luci-app-incus
	# reads this port to build its link, so changing it here is enough.
	option listen ':9443'
	option socket '/var/lib/incus/unix.socket'
	option cert '/etc/uhttpd.crt'
	option key '/etc/uhttpd.key'
	# LuCI ACL group a session must be able to read to be let through. The
	# root login is granted every group, so an administrator passes.
	option acl_group 'luci-app-incus'
