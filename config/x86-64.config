CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_Generic=y
CONFIG_DISPLAY_SUPPORT=y

# Build EVERY kmod OpenWrt ships, exactly like OpenWrt's own buildbot. A router /
# hypervisor / NAS OS must have the whole module set available (arbitrary NICs,
# storage, netfilter features, USB, etc.); curating a subset breaks stock packages
# (e.g. dnsmasq-full needs kmod-nf-conntrack-netlink, which a curated set omits).
# Must be applied from a clean seed (build.sh does `cp x86-64.config .config`):
# defconfig only fills in unset symbols, so ALL_KMODS expands the full ~1000-module
# set only when the seed has no explicit `# kmod-* is not set` lines to override.
CONFIG_ALL_KMODS=y

# rollingWRT kmod overlay: modules OpenWrt does not ship (built in-tree via
# overlay/modules/rwrt.mk). ALL_KMODS covers OpenWrt's own modules; these are ours,
# so they must be selected explicitly (vhost-vsock is required by incus VMs).
CONFIG_PACKAGE_kmod-vhost-vsock=m
CONFIG_PACKAGE_kmod-drm-xe=m
CONFIG_PACKAGE_kmod-drm-gpuvm=m
CONFIG_PACKAGE_kmod-drm-gpusvm=m

# userland: NAS + hypervisor stack
CONFIG_PACKAGE_zfs=m
CONFIG_PACKAGE_cowsql=m
CONFIG_PACKAGE_cowsql-raft=m
CONFIG_PACKAGE_lxc=m
CONFIG_PACKAGE_tar=m
CONFIG_PACKAGE_xz-utils=m
CONFIG_PACKAGE_incus=m
CONFIG_PACKAGE_incus-ui=m
CONFIG_PACKAGE_incus-vm=m
# Reach the incus web UI from LuCI without a client certificate: a small proxy
# to the incus unix socket, gated on the LuCI session, plus the LuCI menu link.
CONFIG_PACKAGE_incus-ui-proxy=m
CONFIG_PACKAGE_luci-app-incus=m
CONFIG_PACKAGE_virglrenderer=m
CONFIG_PACKAGE_qemu-x86_64-softmmu=m
CONFIG_PACKAGE_qemu-img=m
CONFIG_PACKAGE_qemu-ga=m
CONFIG_PACKAGE_qemu-firmware-efi=m
CONFIG_PACKAGE_qemu-firmware-edk2=m
# qemu Incus-feature runtime libs (numa-aware guests, USB redirection over SPICE)
CONFIG_PACKAGE_libnuma=m
CONFIG_PACKAGE_usbredir=m

# GPU userland. NONE of this ships in the base image: rollingWRT's base is a lean
# secure x86-64 OpenWrt, not a GPU/hypervisor appliance. Every mesa variant is an
# installable apk (=m) and each PROVIDES:=libmesa with the same libEGL/libgbm
# sonames, so whatever pulls libmesa (qemu, virglrenderer, an egl-headless service)
# drags in the variant the user chose. MESA_USE_LLVM only affects amd/intel/llvmpipe.
#   apk add libmesa-softpipe  minimal, LLVM-free software driver
#   apk add libmesa-amd       radeonsi (AMD), for native-context / egl-headless
#   apk add libmesa-intel     iris (Intel Xe/i915)
#   apk add libmesa-llvmpipe  fast software rasterizer
CONFIG_MESA_USE_LLVM=y
CONFIG_PACKAGE_libdrm-amdgpu=m
CONFIG_PACKAGE_libmesa-softpipe=m
CONFIG_PACKAGE_libmesa-amd=m
CONFIG_PACKAGE_libmesa-intel=m
CONFIG_PACKAGE_libmesa-llvmpipe=m

# Boot stack: the kernel-owns-UKI apk + the on-device UKI/LUKS/TPM tooling.
# rollingwrt-boot's DEPENDS pull cryptsetup, tpm2-tools, sbsigntool, efibootmgr,
# cpio, zstd, openssl-util and the dm/tpm/sha256 kmods into the base image.
CONFIG_PACKAGE_rollingwrt-boot=y
CONFIG_PACKAGE_rollingwrt-kernel=y
CONFIG_PACKAGE_systemd-boot=m
CONFIG_PACKAGE_tpm2-tools=m
CONFIG_PACKAGE_sbctl=m
CONFIG_QEMU_UI_SPICE=y
# Incus needs these qemu features: seccomp, usb (libusb), png (via vnc), zstd
CONFIG_QEMU_SECCOMP=y
CONFIG_QEMU_DEV_USB=y
CONFIG_QEMU_UI_VNC=y
CONFIG_QEMU_ZSTD=y
# CONFIG_PACKAGE_libclang is not set
# CONFIG_PACKAGE_glslang is not set
# CONFIG_PACKAGE_libmesa-virgl is not set

# Persistent /var: OpenWrt defaults /var -> /tmp (tmpfs, wiped each boot), which
# would erase Incus/ZFS/service state (/var/lib/incus etc.) on reboot. This makes
# /var a real directory on the persistent root; only /var/run stays tmpfs (runtime
# pid/socket files, correctly ephemeral). Required for the hypervisor/NAS role.
CONFIG_TARGET_ROOTFS_PERSIST_VAR=y

# Image output: a rootfs tarball for the rollingWRT installer to extract onto the
# LUKS/plain root. We build our own signed UKI + installer, so OpenWrt's own
# bootable grub/EFI disk images are not needed.
CONFIG_TARGET_ROOTFS_TARGZ=y
# CONFIG_TARGET_ROOTFS_SQUASHFS is not set
# CONFIG_GRUB_IMAGES is not set
# CONFIG_GRUB_EFI_IMAGES is not set

# Custom busybox config so the per-applet selections below actually apply (the
# default config ignores them). defconfig fills the rest from busybox defaults.
CONFIG_BUSYBOX_CUSTOM=y
# cpio (create mode) for rollingwrt-mkinitramfs (cpio -o -H newc); OpenWrt has no
# standalone cpio package and the applet is off by default.
CONFIG_BUSYBOX_CONFIG_CPIO=y
CONFIG_BUSYBOX_CONFIG_FEATURE_CPIO_O=y
# blkid + uname so the initramfs /init can resolve root=UUID= and get KVER;
# mdev to populate /dev (incl. /dev/tpmrm0) inside the initramfs.
CONFIG_BUSYBOX_CONFIG_BLKID=y
CONFIG_BUSYBOX_CONFIG_FEATURE_BLKID_TYPE=y
CONFIG_BUSYBOX_CONFIG_UNAME=y
CONFIG_BUSYBOX_CONFIG_UNAME_OSNAME=y
CONFIG_BUSYBOX_CONFIG_MDEV=y
CONFIG_BUSYBOX_CONFIG_FEATURE_MDEV_CONF=y
CONFIG_BUSYBOX_CONFIG_FEATURE_MDEV_EXEC=y
# install (incl. -D) used by rollingwrt-mkinitramfs to assemble the initrd tree.
CONFIG_BUSYBOX_CONFIG_INSTALL=y
# module tools: OpenWrt boots via procd's kmodloader and ships NO insmod/modprobe
# binary, and these busybox applets are off by default. The initramfs gate needs
# them to load the unlock/tpm/fat modules (depmod/modinfo let mkinitramfs build a
# working modules.dep so modprobe resolves deps).
CONFIG_BUSYBOX_CONFIG_INSMOD=y
CONFIG_BUSYBOX_CONFIG_RMMOD=y
CONFIG_BUSYBOX_CONFIG_MODPROBE=y
CONFIG_BUSYBOX_CONFIG_DEPMOD=y
CONFIG_BUSYBOX_CONFIG_MODINFO=y
CONFIG_BUSYBOX_CONFIG_FEATURE_MODUTILS_ALIAS=y
CONFIG_BUSYBOX_CONFIG_FEATURE_MODUTILS_SYMBOLS=y
# blkid needs volume_id filesystem detectors, else `blkid <dev>` prints nothing
# and the initramfs cannot resolve root=UUID=. EXT is the root fs; the others are
# the pool/ESP filesystems the system uses.
CONFIG_BUSYBOX_CONFIG_FEATURE_VOLUMEID_EXT=y
CONFIG_BUSYBOX_CONFIG_FEATURE_VOLUMEID_BTRFS=y
CONFIG_BUSYBOX_CONFIG_FEATURE_VOLUMEID_F2FS=y
CONFIG_BUSYBOX_CONFIG_FEATURE_VOLUMEID_FAT=y
CONFIG_BUSYBOX_CONFIG_FEATURE_VOLUMEID_LUKS=y

# rollingWRT branding (VERSION_DIST drives NAME/PRETTY_NAME/banner-version/LuCI;
# os-release ID is pinned back to openwrt in build.sh for ecosystem compatibility).
# IMAGEOPT is the parent gate: without it defconfig drops VERSIONOPT/PREINITOPT and
# their children (the version strings and the failsafe switch).
CONFIG_IMAGEOPT=y
CONFIG_VERSIONOPT=y
CONFIG_VERSION_DIST="rollingWRT"
CONFIG_VERSION_MANUFACTURER="rollingWRT"
CONFIG_VERSION_HOME_URL="https://github.com/cmspam/rollingwrt"
CONFIG_VERSION_BUG_URL="https://github.com/cmspam/rollingwrt/issues"
CONFIG_VERSION_SUPPORT_URL="https://github.com/cmspam/rollingwrt"
CONFIG_VERSION_MANUFACTURER_URL="https://github.com/cmspam/rollingwrt"

# LuCI web UI over HTTPS (default bootstrap theme)
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-openssl=y

# security: no unauthenticated failsafe root shell (TPM/LUKS/SB product).
# PREINITOPT (under IMAGEOPT above) is the gate for the failsafe switch.
CONFIG_PREINITOPT=y
CONFIG_TARGET_PREINIT_DISABLE_FAILSAFE=y
