CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_Generic=y

# A live installer image: boots entirely in RAM (initramfs), runs the installer.
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_ROOTFS_INITRAMFS_SEPARATE=y
# CONFIG_TARGET_ROOTFS_SQUASHFS is not set
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
# CONFIG_TARGET_ROOTFS_TARGZ is not set
# CONFIG_GRUB_IMAGES is not set
# CONFIG_GRUB_EFI_IMAGES is not set
# CONFIG_ISO_IMAGES is not set
# CONFIG_VMDK_IMAGES is not set

# The outer tools rollingwrt-install needs (it chroots into the extracted rootfs to
# run rollingwrt-uki etc., so the heavy tools come from the rootfs, not from here).
# sgdisk is the scripting sub-package of gptfdisk (the one the installer calls).
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_dosfstools=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_cryptsetup=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_partx-utils=y

# module tooling + the LUKS/TPM module chain so the installer can luksFormat/open
# and reach the TPM for enroll (mirrors the boot initramfs chain).
CONFIG_PACKAGE_kmod-tpm=y
CONFIG_PACKAGE_kmod-tpm-tis=y
CONFIG_PACKAGE_kmod-dm=y
CONFIG_PACKAGE_kmod-crypto-user=y
CONFIG_PACKAGE_kmod-crypto-sha256=y
CONFIG_PACKAGE_kmod-crypto-hmac=y
CONFIG_PACKAGE_kmod-crypto-cbc=y
CONFIG_PACKAGE_kmod-fs-vfat=y

# busybox applets the installer + chroot need (module tools, blkid volume_id, etc.)
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_BUSYBOX_CONFIG_INSTALL=y
CONFIG_BUSYBOX_CONFIG_CHROOT=y
CONFIG_BUSYBOX_CONFIG_BLKID=y
CONFIG_BUSYBOX_CONFIG_FEATURE_BLKID_TYPE=y
CONFIG_BUSYBOX_CONFIG_FEATURE_VOLUMEID_EXT=y
CONFIG_BUSYBOX_CONFIG_FEATURE_VOLUMEID_FAT=y
CONFIG_BUSYBOX_CONFIG_FEATURE_VOLUMEID_LUKS=y
CONFIG_BUSYBOX_CONFIG_INSMOD=y
CONFIG_BUSYBOX_CONFIG_MODPROBE=y
CONFIG_BUSYBOX_CONFIG_DEPMOD=y
CONFIG_BUSYBOX_CONFIG_MODINFO=y
CONFIG_BUSYBOX_CONFIG_FEATURE_MODUTILS_ALIAS=y
CONFIG_BUSYBOX_CONFIG_FEATURE_MODUTILS_SYMBOLS=y
