#!/bin/sh
# rollingWRT installer.
#
# Lays rollingWRT onto a machine: partition, encrypt (LUKS2), an ext4 root, an
# apk bootstrap of the OpenWrt base plus our feed, then the boot ceremony that is
# just the first run of the on-device assembler (rollingwrt-secureboot,
# rollingwrt-uki, rollingwrt-tpm-enroll reading /etc/rollingwrt/uki.conf). The
# same scripts an `apk upgrade` later triggers, so install and update share a path.
#
# The root the boot gate expects: a LUKS partition holding a plain ext4 root
# (the initramfs does `mount /dev/mapper/croot /newroot`; it does not import a
# pool), plus a vfat ESP that carries the signed PCR-11 policy. ZFS, when asked
# for, is a SEPARATE data pool for incus/NAS storage, not the root.
#
# Runnable two ways:
#   interactive : `rollingwrt-install`         (asks, confirms, installs)
#   scripted    : source it, set CFG[*], call the stages (the image builders and
#                 the test harness do this so they never drift from the real path)
set -eu

# dir this script (and rollingwrt-common.sh) live in. A scripted caller that sources
# this file sets RWRT_INSTALLER_DIR first, since POSIX `.` does not change $0.
HERE="${RWRT_INSTALLER_DIR:-$(cd "$(dirname "$0")" && pwd)}"
# shellcheck source=rollingwrt-common.sh
. "$HERE/rollingwrt-common.sh"

# ---------------------------------------------------------------- config + output
# CFG holds every install decision. Defaults here; the wizard or parse_args fill
# the rest. A scripted caller sets CFG[*] directly and skips the wizard.
CFG_disk=""; CFG_mode="auto"; CFG_reserve=""
CFG_esp=""; CFG_root=""                      # resolved partition devices
CFG_encrypt="yes"; CFG_passphrase=""
CFG_tpm_unlock="yes"                        # seal the LUKS key to the TPM (UEFI+TPM only); no = passphrase at every boot
# Independent role toggles (the wizard asks each). CFG_profile is an OPTIONAL scripted
# shortcut (hypervisor|nas|minimal|router) that expands to these; leave it empty to use
# the toggles directly.
CFG_virt="yes"; CFG_zfs="yes"; CFG_samba="no"   # LuCI is always installed, not a toggle
CFG_profile=""
CFG_extra_pkgs=""; CFG_extra_kmods=""
CFG_hostname="rollingwrt"; CFG_password=""; CFG_sshkey=""
CFG_cmdline_extra=""                        # user additions to the kernel cmdline
CFG_firmware=""                             # efi | bios (probed)
ASSUME_YES="${ASSUME_YES:-no}"              # skip the destructive confirm (scripted)
TARGET="${TARGET:-/mnt/rwrt}"

say(){ printf '%s\n' "${C_B}==>${C_0} $*"; }
info(){ printf '    %s\n' "$*"; }
warn(){ printf '%s\n' "${C_Y}!! ${C_0} $*" >&2; }
die(){ printf '%s\n' "${C_R}xx ${C_0} $*" >&2; exit 1; }

# ---------------------------------------------------------------- small helpers
prompt(){ # question default -> REPLY
	printf '%s' "$1"; [ -n "${2:-}" ] && printf ' [%s]' "$2"; printf ': '
	IFS= read -r REPLY || REPLY=""
	# fill in the default when the user just hits enter. Written as `|| assign` (not
	# `[ -z ] && assign`) so the function ALWAYS returns 0: under `set -e` a non-empty
	# answer would make a trailing `&&` test fail and kill the whole installer.
	[ -n "$REPLY" ] || REPLY="${2:-}"
}
prompt_secret(){ printf '%s: ' "$1"; stty -echo 2>/dev/null || true; IFS= read -r REPLY || REPLY=""; stty echo 2>/dev/null || true; printf '\n'; }
yn(){ case "$1" in y|Y|yes|YES|Yes|true|1) echo yes;; *) echo no;; esac; }  # normalize a yes/no answer
pick(){ # title default opt... -> REPLY  (accepts a number or a typed value)
	title="$1"; def="$2"; shift 2; i=1
	printf '%s\n' "$title"
	for o in "$@"; do printf '  %d) %s\n' "$i" "$o"; i=$((i+1)); done
	prompt "  choose" "$def"; n="$REPLY"
	case "$n" in ''|*[!0-9]*) : ;; *) i=1; for o in "$@"; do [ "$i" = "$n" ] && { REPLY="$o"; return; }; i=$((i+1)); done ;; esac
}
size_to_bytes(){ # 100G / 512M / 2T -> bytes
	v="$1"; n="${v%[GgMmTtKk]}"; u="${v#"$n"}"
	case "$u" in K|k) echo $((n*1024));; M|m) echo $((n*1024*1024));; G|g) echo $((n*1024*1024*1024));;
		T|t) echo $((n*1024*1024*1024*1024));; *) echo "$n";; esac
}
psep(){ case "$1" in *[0-9]) echo p;; *) echo "";; esac; }   # nvme0n1 -> p, sda -> ''
partdev(){ echo "$1$(psep "$1")$2"; }                        # disk, index -> /dev/nvme0n1p2

# fetch an SSH key spec into REPLY: github:USER / gh:USER / gl:USER / @file / raw key
resolve_sshkey(){
	case "$1" in
		github:*|gh:*) u="${1#github:}"; u="${u#gh:}"; REPLY="$(curl -fsSL "https://github.com/$u.keys" 2>/dev/null || true)";;
		gitlab:*|gl:*) u="${1#gitlab:}"; u="${u#gl:}"; REPLY="$(curl -fsSL "https://gitlab.com/$u.keys" 2>/dev/null || true)";;
		@*) REPLY="$(cat "${1#@}" 2>/dev/null || true)";;
		ssh-*) REPLY="$1";;
		"") REPLY="";;
		*) REPLY="$1";;
	esac
}

# --------------------------------------------------------------------- preflight
is_uefi(){ [ -d /sys/firmware/efi ]; }
has_tpm(){ [ -c /dev/tpmrm0 ] || [ -c /dev/tpm0 ]; }
setup_mode(){ # 0 if firmware Secure Boot is in Setup Mode
	f=/sys/firmware/efi/efivars/SetupMode-8be4df61-93ca-11d2-aa0d-00e098032b8c
	[ -r "$f" ] && [ "$(tail -c1 "$f" | od -An -tu1 | tr -d ' ')" = 1 ]
}
preflight(){
	CFG_firmware="$(is_uefi && echo efi || echo bios)"
	for t in sgdisk cryptsetup mkfs.ext4 mkfs.fat apk blkid lsblk wipefs; do
		command -v "$t" >/dev/null 2>&1 || die "missing required tool: $t"
	done
	say "Hardware"
	info "firmware       : $CFG_firmware$( [ "$CFG_firmware" = bios ] && echo '  (UEFI needed for Secure Boot / signed UKI / TPM unlock)')"
	if [ "$CFG_firmware" = efi ]; then
		info "secure boot    : $(setup_mode && echo 'Setup Mode (keys enroll automatically)' || echo 'User Mode (enter firmware once to clear keys, then it self-enrolls)')"
		info "TPM 2.0        : $(has_tpm && echo present || echo 'absent (encryption falls back to passphrase-only)')"
	fi
	if [ "$CFG_firmware" = bios ]; then
		info "boot           : GRUB in the MBR (no UKI / Secure Boot / TPM - BIOS has none); whole-disk install only"
		info "encryption     : LUKS with a passphrase (no TPM auto-unlock on BIOS)"
	fi
}

list_disks(){ lsblk -dnro NAME,SIZE,MODEL 2>/dev/null | awk '$1 !~ /^(loop|sr|ram)/{print}'; }

# ----------------------------------------------------------------------- wizard
wizard(){
	say "Target disk"
	list_disks | sed 's/^/    /'
	def="$(list_disks | awk 'NR==1{print $1}')"
	prompt "  disk to install to" "$def"; CFG_disk="/dev/${REPLY#/dev/}"
	[ -b "$CFG_disk" ] || die "not a block device: $CFG_disk"

	# BIOS is whole-disk only (GRUB's core image dictates the GPT layout); UEFI can
	# also install into free space or onto existing partitions.
	if [ "$CFG_firmware" = bios ]; then
		pick "How should the disk be used?" 1 \
			"Whole disk (erase $CFG_disk, use all of it)" \
			"Whole disk, reserve free space at the end"
	else
		pick "How should the disk be used?" 1 \
			"Whole disk (erase $CFG_disk, use all of it)" \
			"Whole disk, reserve free space at the end" \
			"Use existing free space (leave current partitions alone)" \
			"Custom (you picked partitions already)"
	fi
	case "$REPLY" in
		Whole\ disk,\ reserve*) CFG_mode="auto-reserve"; prompt "  free space to leave" "100G"; CFG_reserve="$REPLY";;
		Use\ existing*)         CFG_mode="freespace";;
		Custom*)                CFG_mode="custom";
			prompt "  ESP partition (existing, will be shared not wiped)" ""; CFG_esp="$REPLY"
			prompt "  root partition (will be ENCRYPTED and erased)" ""; CFG_root="$REPLY";;
		*)                      CFG_mode="auto";;
	esac

	# Roles are independent - answer each. The base is always a working OpenWrt router;
	# these add on top, in any combination.
	say "Roles (what this box does; the base is always a router)"
	CFG_profile=""
	prompt "  Virtualization - Incus containers + QEMU/KVM VMs?" "$CFG_virt"; CFG_virt="$(yn "$REPLY")"
	prompt "  ZFS storage pools?" "$CFG_zfs"; CFG_zfs="$(yn "$REPLY")"
	prompt "  File sharing - Samba (SMB/CIFS)?" "$CFG_samba"; CFG_samba="$(yn "$REPLY")"

	# Extra apk packages on top of the selected roles (from OpenWrt's feeds or ours),
	# e.g. "tmux htop wireguard-tools". Resolved at install time like the role packages.
	prompt "Extra packages to install (space-separated, blank for none)" ""; CFG_extra_pkgs="$REPLY"

	prompt "Encrypt the root with LUKS?" "$CFG_encrypt"; CFG_encrypt="$(yn "$REPLY")"
	if [ "$CFG_encrypt" = yes ]; then
		while :; do
			prompt_secret "  passphrase"; p1="$REPLY"
			prompt_secret "  repeat passphrase"; [ "$REPLY" = "$p1" ] && { CFG_passphrase="$p1"; break; }
			warn "passphrases did not match"
		done
		# TPM auto-unlock is a separate choice, offered only where it can work (UEFI + a
		# TPM). Off means the passphrase is entered at every boot; on seals the key so a
		# clean boot needs no passphrase, with the passphrase kept as the fallback.
		if [ "$CFG_firmware" = efi ] && has_tpm; then
			prompt "  Unlock automatically with the TPM? (no = enter the passphrase every boot)" "$CFG_tpm_unlock"; CFG_tpm_unlock="$(yn "$REPLY")"
		else
			CFG_tpm_unlock=no
		fi
	fi

	prompt "Hostname" "rollingwrt"; CFG_hostname="$REPLY"
	# Admin access: an SSH key and/or a root password, set independently. At least one
	# is required; the root password is what the console login (ttylogin) checks.
	prompt "Admin SSH key (github:USER, gitlab:USER, @file, or paste a key; blank to skip)" ""
	if [ -n "$REPLY" ]; then
		resolve_sshkey "$REPLY"; CFG_sshkey="$REPLY"
		if [ -n "$CFG_sshkey" ]; then
			info "fetched $(printf '%s' "$CFG_sshkey" | grep -c .) key(s):"
			printf '%s\n' "$CFG_sshkey" | sed 's/^\(.\{0,50\}\).*/      \1.../'
			prompt "  use these keys?" "yes"; [ "$REPLY" = yes ] || CFG_sshkey=""
		else warn "could not fetch any key for that spec"; fi
	fi
	# Root password: optional when a key is set (but recommended - the console needs it),
	# required when no key was set.
	set_pw=yes
	if [ -n "$CFG_sshkey" ]; then
		prompt "Set a root password too? (for console login)" "yes"; set_pw="$(yn "$REPLY")"
	fi
	if [ "$set_pw" = yes ]; then
		while :; do
			prompt_secret "  root password"; p1="$REPLY"
			prompt_secret "  repeat password"
			[ "$REPLY" = "$p1" ] && [ -n "$p1" ] && { CFG_password="$p1"; break; }
			warn "passwords did not match (or were empty)"
		done
	fi
}

# review + edit the kernel command line before the UKI is built (user asked for
# this). The base rollingwrt.* args are computed later once the LUKS UUID exists;
# here we only take extra args to append.
review_cmdline(){
	say "Kernel command line"
	info "base (filled in after partitioning): rollingwrt.root=UUID=<root> rollingwrt.crypt=$([ "$CFG_encrypt" = yes ] && echo 1 || echo 0) rollingwrt.name=$RWRT_MAPPER"
	# Serial console is opt-in: forcing console=ttyS0 on hardware with no serial port can
	# stop it booting, so it is off by default and added only for headless serial machines.
	prompt "Enable serial console (console=ttyS0,115200)? only for headless/serial hardware" "no"
	if [ "$REPLY" = yes ]; then
		case " $CFG_cmdline_extra " in
			*" console=ttyS0"*) : ;;
			*) CFG_cmdline_extra="${CFG_cmdline_extra:+$CFG_cmdline_extra }console=ttyS0,115200 console=tty0" ;;
		esac
	fi
	prompt "extra kernel args to append (blank for none)" "$CFG_cmdline_extra"; CFG_cmdline_extra="$REPLY"
}

confirm_destructive(){
	[ "$ASSUME_YES" = yes ] && return 0
	say "About to install rollingWRT"
	case "$CFG_mode" in
		auto)         info "This ERASES all of $CFG_disk.";;
		auto-reserve) info "This ERASES $CFG_disk but leaves $CFG_reserve free at the end.";;
		freespace)    info "This uses free space on $CFG_disk; existing partitions are NOT touched.";;
		custom)       info "This ENCRYPTS and erases $CFG_root and shares the ESP $CFG_esp; nothing else is touched.";;
	esac
	prompt "Type YES to proceed" ""; [ "$REPLY" = YES ] || die "aborted"
}

# --------------------------------------------------------------- disk teardown
dismantle_layers(){ # best-effort teardown of any stacking on a disk before we wipe
	d="$1"
	# unmount anything already mounted off this disk (a re-run, or a prior OS);
	# lazy-unmount if a plain unmount says the mount is busy.
	for mp in $(lsblk -nro MOUNTPOINT "$d" 2>/dev/null | grep -v '^$' | sort -r); do
		umount -R "$mp" 2>/dev/null || umount -Rl "$mp" 2>/dev/null || true
	done
	for m in $(lsblk -nro NAME,TYPE "$d" 2>/dev/null | awk '$2=="crypt"{print $1}'); do
		cryptsetup close "$m" 2>/dev/null || dmsetup remove -f "$m" 2>/dev/null || true
	done
	command -v zpool >/dev/null 2>&1 && zpool labelclear -f "$d" 2>/dev/null || true
	for p in $(lsblk -nro NAME "$d" 2>/dev/null | tail -n +2); do wipefs -af "/dev/$p" 2>/dev/null || true; done
	wipefs -af "$d" 2>/dev/null || true
	dd if=/dev/zero of="$d" bs=1M count=16 conv=fsync 2>/dev/null || true
}

# -------------------------------------------------------------- partitioning
# UEFI layout: p1 = ESP (ef00, vfat), p2 = LUKS root (8304). An optional ZFS data
# partition can take the tail. We never carve a scratch partition (apk needs none).
partition(){
	case "$CFG_mode" in
		auto|auto-reserve) partition_auto;;
		freespace)         partition_freespace;;
		custom)            partition_custom;;
	esac
	udevadm settle 2>/dev/null || sleep 1
}
partition_auto(){
	say "Partitioning $CFG_disk (mode $CFG_mode, $CFG_firmware)"
	dismantle_layers "$CFG_disk"
	sgdisk --zap-all "$CFG_disk" >/dev/null
	# p1 is always the FAT boot partition. On UEFI it is the ESP (systemd-boot + UKI);
	# on BIOS GRUB's core image bakes in `configfile (hd0,gpt1)/boot/grub/grub.cfg`, so
	# it MUST be partition 1 and hold the kernel + unlock initramfs + grub.cfg.
	sgdisk --new=1:0:+512M --typecode=1:ef00 --change-name=1:"$RWRT_ESP_LABEL" "$CFG_disk" >/dev/null
	rootnum=2
	if [ "$CFG_firmware" = bios ]; then
		# GPT has no post-MBR gap, so grub-bios-setup embeds core.img in a dedicated
		# BIOS boot partition (type ef02). It is found by type, so its number is free.
		sgdisk --new=2:0:+1M --typecode=2:ef02 --change-name=2:"rwrt-biosboot" "$CFG_disk" >/dev/null
		rootnum=3
	fi
	if [ "$CFG_mode" = auto-reserve ]; then
		rmib=$(( $(size_to_bytes "$CFG_reserve") / 1024 / 1024 ))
		sgdisk --new=$rootnum:0:-"${rmib}"M --typecode=$rootnum:8304 --change-name=$rootnum:"$RWRT_ROOT_LABEL" "$CFG_disk" >/dev/null
	else
		sgdisk --new=$rootnum:0:0 --typecode=$rootnum:8304 --change-name=$rootnum:"$RWRT_ROOT_LABEL" "$CFG_disk" >/dev/null
	fi
	CFG_esp="$(partdev "$CFG_disk" 1)"; CFG_root="$(partdev "$CFG_disk" "$rootnum")"
	MADE_ESP=yes
}
partition_freespace(){
	[ "$CFG_firmware" = bios ] && die "BIOS install is whole-disk only (GRUB's core image needs partition 1 to be the boot FAT + a BIOS boot partition); choose Whole disk"
	say "Partitioning free space on $CFG_disk"
	# sgdisk 0 = next free slot / next free sector; do NOT zap existing partitions.
	sgdisk --new=0:0:+512M --typecode=0:ef00 --change-name=0:"$RWRT_ESP_LABEL" "$CFG_disk" >/dev/null
	sgdisk --largest-new=0 --typecode=0:8304 --change-name=0:"$RWRT_ROOT_LABEL" "$CFG_disk" >/dev/null
	udevadm settle 2>/dev/null || sleep 1
	CFG_esp="/dev/disk/by-partlabel/$RWRT_ESP_LABEL"; CFG_root="/dev/disk/by-partlabel/$RWRT_ROOT_LABEL"
	MADE_ESP=yes
}
partition_custom(){
	[ "$CFG_firmware" = bios ] && die "BIOS install is whole-disk only (GRUB's core image needs partition 1 to be the boot FAT + a BIOS boot partition); choose Whole disk"
	say "Using existing partitions"
	[ -b "$CFG_esp" ] || die "ESP $CFG_esp is not a block device"
	[ -b "$CFG_root" ] || die "root $CFG_root is not a block device"
	# Share, do not wipe, an existing ESP: only mkfs it if it is not already vfat.
	if blkid "$CFG_esp" 2>/dev/null | grep -qi 'TYPE="vfat"'; then MADE_ESP=no; info "sharing existing ESP $CFG_esp"
	else MADE_ESP=yes; fi
}

# ------------------------------------------------------------- filesystems
setup_target(){
	say "Creating filesystems"
	if [ "${MADE_ESP:-yes}" = yes ]; then mkfs.fat -F32 -n "$RWRT_ESP_LABEL" "$CFG_esp" >/dev/null; fi
	if [ "$CFG_encrypt" = yes ]; then
		printf '%s' "$CFG_passphrase" | cryptsetup luksFormat --type luks2 --batch-mode --label "$RWRT_ROOT_LABEL" "$CFG_root" -
		printf '%s' "$CFG_passphrase" | cryptsetup open "$CFG_root" "$RWRT_MAPPER" -
		ROOT_DEV="/dev/mapper/$RWRT_MAPPER"
	else
		ROOT_DEV="$CFG_root"
	fi
	mkfs.ext4 -F -q -L "$RWRT_ROOT_LABEL" "$ROOT_DEV"
	mkdir -p "$TARGET"; mount "$ROOT_DEV" "$TARGET"
	mkdir -p "$TARGET/boot/efi"; mount "$CFG_esp" "$TARGET/boot/efi"
	# the UUID the boot gate matches on is the LUKS partition (or the plain root)
	ROOT_UUID="$(blkid -s UUID -o value "$CFG_root")"
}

# --------------------------------------------------------------- apk deploy
profile_pkgs(){
	# A CFG_profile value is a scripted shortcut that expands to the role toggles; the
	# wizard leaves CFG_profile empty and sets the toggles directly. Roles are additive
	# and independent, so any combination works (e.g. virt + samba on one box).
	case "${CFG_profile:-}" in
		hypervisor)     CFG_virt=yes; CFG_zfs=yes; CFG_samba=no;;
		nas)            CFG_virt=no;  CFG_zfs=yes; CFG_samba=yes;;
		minimal|router) CFG_virt=no;  CFG_zfs=no;  CFG_samba=no;;
	esac
	# LuCI is standard on every rollingWRT box, not an option: always install the web
	# admin interface. Roles then add their LuCI apps on top.
	p="luci"
	# virt pulls the Incus web UI too: luci-app-incus brings incus-ui-proxy + incus-ui and
	# the LuCI menu link, so the Incus management UI is there out of the box.
	[ "$(yn "${CFG_virt:-no}")"  = yes ] && p="$p incus incus-vm qemu-x86_64-softmmu luci-app-incus"
	[ "$(yn "${CFG_zfs:-no}")"   = yes ] && p="$p zfs kmod-fs-zfs"
	# samba brings its LuCI app so shares are manageable from the web UI
	[ "$(yn "${CFG_samba:-no}")" = yes ] && p="$p samba4-server luci-app-samba4"
	echo "$p"
}
deploy_apk(){
	say "Installing the base system (apk)"
	# OpenWrt's /var is a symlink to /tmp; lay it (and /tmp) before apk touches the root, so
	# apk --initdb's /var/cache/apk and base-files' own /var->/tmp symlink both land cleanly.
	# If /var were left a real directory, base-files could not commit its symlink and /var
	# would be broken on the installed system.
	mkdir -p "$TARGET/tmp/lock" "$TARGET/tmp/run" "$TARGET/etc/rc.d"
	[ -e "$TARGET/var" ] || ln -s /tmp "$TARGET/var"
	apk --root "$TARGET" --initdb add >/dev/null 2>&1 || apk --root "$TARGET" --initdb >/dev/null 2>&1 || true
	mkdir -p "$TARGET/etc/apk/keys"
	# trusted keys: OpenWrt's (for the base feeds) + ours (for our feed)
	for k in /etc/apk/keys/* "$HERE"/keys/*; do [ -f "$k" ] && cp -f "$k" "$TARGET/etc/apk/keys/"; done 2>/dev/null || true
	# OpenWrt's feeds give the whole userland including the target feed (libc, dropbear,
	# grub2, ... that we do not rebuild). That target feed also carries OpenWrt's own kernel
	# and kmods, but ours are versioned <ver>.<vermagic-decimal> which apk sorts ABOVE
	# OpenWrt's <ver>, so the device installs our kernel and our kmods, never OpenWrt's.
	# We list every OpenWrt package feed that base-files' distfeeds carries (base, packages,
	# luci, routing, telephony, video) so the install-time closure matches what the device
	# resolves against after boot: the hypervisor profile pulls qemu, whose mesa/libepoxy
	# come from the video feed, and luci-app-incus from the luci feed. OpenWrt's own kernel
	# and kmods (the targets/kmods feed) are deliberately NOT listed; ours supersede them.
	{
		echo "$OWRT_SNAP/targets/x86/64/packages/packages.adb"
		for f in base packages luci routing telephony video; do
			echo "$OWRT_SNAP/packages/x86_64/$f/packages.adb"
		done
		echo "$RWRT_REL/snapshot/packages.adb"
		for b in 1 2 3; do echo "$RWRT_REL/snapshot-kmods-$b/packages.adb"; done
	} > "$TARGET/etc/apk/repositories"
	pkgs="$RWRT_BASE_PKGS $(profile_pkgs) $CFG_extra_pkgs $CFG_extra_kmods"
	# Offline install: apk runs each package's post-install CHROOTED by default, where
	# IPKG_INSTROOT is empty, so OpenWrt's post-install scripts take the RUNNING-system
	# path and try to start services (procd) - which hangs, since procd/uci/var-lock do
	# not exist in a fresh target. Mirror OpenWrt's own rootfs.mk offline idiom instead:
	# --force-no-chroot runs the scripts in this environment (not the target) and
	# --preserve-env passes IPKG_INSTROOT down, so the scripts take the install path
	# (enable rc.d symlinks under $TARGET, defer service starts to first boot).
	# The post-installs (procd service enable) need these runtime dirs to exist, exactly
	# as OpenWrt's rootfs.mk pre-creates them before running the scripts; without them the
	# procd lock/enable fails on the fresh target and the install stalls. OpenWrt's /var is
	# a symlink to /tmp, so create the dirs under /tmp and lay /var as that symlink here;
	# creating /var/* directly would leave /var a real dir and base-files could not commit
	# its /var->/tmp symlink (breaking /var on the installed system).
	mkdir -p "$TARGET/tmp/lock" "$TARGET/tmp/run" "$TARGET/etc/rc.d"
	[ -e "$TARGET/var" ] || ln -s /tmp "$TARGET/var"
	# Do NOT abort the whole install if apk reports an error on some package: a single bad
	# add-on (e.g. a feed inconsistency on an optional package) must not leave a half-installed
	# box with no boot image. Tolerate apk's non-zero exit, then require that the essentials -
	# the kernel and its modules - actually landed; without those the machine cannot boot, so
	# that IS fatal. run_ceremony builds the boot image from the installed kernel afterwards.
	# shellcheck disable=SC2086
	IPKG_INSTROOT="$TARGET" apk --root "$TARGET" --force-no-chroot --preserve-env add $pkgs \
		|| warn "apk reported errors on one or more packages (see above); continuing"
	[ -n "$(ls "$TARGET/lib/modules" 2>/dev/null)" ] && [ -n "$(ls "$TARGET"/boot/vmlinuz* 2>/dev/null)" ] \
		|| die "the kernel did not install (apk failure); cannot build a bootable system"

	# apk's offline install materialises a package "alternative" (a priority-ranked symlink
	# in /lib/apk/packages/*.alternatives) only when that package's post-install calls
	# update_alternatives. Packages that instead rely on apk's trigger are missed - notably
	# uclient-fetch, which ships the /usr/bin/wget that apk ITSELF execs to fetch feeds
	# (apk-mbedtls depends on wget-any). Without it a fresh install cannot apk update/upgrade
	# at all, the whole point of a rolling distro. Create every alternative ourselves the same
	# way the post-installs do: OpenWrt's update_alternatives from the target's
	# /lib/functions.sh, with IPKG_INSTROOT pointing at the target (its `root`). No chroot -
	# /dev and /proc are not bound under $TARGET yet, and this is pure symlink work.
	if [ -f "$TARGET/lib/functions.sh" ]; then
		for a in "$TARGET"/lib/apk/packages/*.alternatives; do
			[ -e "$a" ] || continue
			p=${a##*/}
			IPKG_INSTROOT="$TARGET" sh -c '. "$IPKG_INSTROOT/lib/functions.sh"; update_alternatives install "$1"' _ "${p%.alternatives}" >/dev/null 2>&1 || true
		done
	fi

	# Persistent /var. rollingWRT is a disk hypervisor/NAS, not a flash router: incus
	# (/var/lib/incus), zfs and sbctl keep state under /var. base-files (pulled from OpenWrt's
	# feed, built WITHOUT CONFIG_TARGET_ROOTFS_PERSIST_VAR) ships /var as a symlink into tmpfs
	# (/tmp), so all that state is wiped every reboot. Replicate OpenWrt's PERSIST_VAR layout
	# on the installed root (base-files Makefile: real /var dir, only /var/run -> /tmp/run kept
	# ephemeral). Done AFTER apk (which needs the /var->/tmp symlink for its transient
	# cache/locks) and before the ceremony.
	# The persistent subdirs must exist NOW, not just after first boot: run_ceremony chroots in
	# and runs sbctl, whose landlock sandbox opens /var/lib to build its ruleset and ABORTS if
	# the dir is missing ("populating ruleset for /var/lib: no such file"), so create-keys makes
	# no keys and Secure Boot enrolment fails. During apk /var was the /tmp symlink, so nothing
	# laid a real /var/lib. /etc/init.d/boot recreates lock+log at boot, but the ceremony runs
	# before any boot, so lay the whole persistent skeleton here.
	rm -f "$TARGET/var"
	mkdir -p "$TARGET/var/lib" "$TARGET/var/log" "$TARGET/var/lock" "$TARGET/var/tmp" "$TARGET/var/cache"
	ln -s /tmp/run "$TARGET/var/run"
}

# ------------------------------------------------------------- configure
configure_system(){
	say "Configuring the system"
	# Everything here is done from the OUTSIDE (host-side edits of the target's files), not
	# via chroot: at this stage the target has no procd/ubus and no generated config, so a
	# `chroot passwd`/`chroot init.d enable` silently fails (passwd reads /dev/tty not our
	# pipe; the network enable needs procd). The hostname is set by uci-default below,
	# because OpenWrt reads the uci system.hostname, not /etc/hostname.
	# Login banner. base-files (from OpenWrt's feed) ships the OpenWrt banner; replace it
	# with ours. /etc/banner is a config file, so an apk base-files upgrade keeps this.
	cat > "$TARGET/etc/banner" <<'BANNER'
           _ _ _           __        ______ _____
 _ __ ___ | | (_)_ __   __ \ \      / /  _ \_   _|
| '__/ _ \| | | | '_ \ / _` \ \ /\ / /| |_) || |
| | | (_) | | | | | | | (_| |\ V  V / |  _ < | |
|_|  \___/|_|_|_|_| |_|\__, | \_/\_/  |_| \_\|_|
                       |___/
 rolling OpenWrt for x86-64, unlocked and up to date
BANNER
	# root password / ssh key
	if [ -n "$CFG_sshkey" ]; then
		mkdir -p "$TARGET/etc/dropbear" "$TARGET/root/.ssh"
		printf '%s\n' "$CFG_sshkey" > "$TARGET/root/.ssh/authorized_keys"
		printf '%s\n' "$CFG_sshkey" > "$TARGET/etc/dropbear/authorized_keys"
		chmod 600 "$TARGET/root/.ssh/authorized_keys" "$TARGET/etc/dropbear/authorized_keys"
	fi
	# Root password: write the shadow hash directly. openssl is on the installer medium.
	if [ -n "$CFG_password" ]; then
		ph="$(openssl passwd -6 "$CFG_password" 2>/dev/null || true)"
		if [ -n "$ph" ] && [ -f "$TARGET/etc/shadow" ]; then
			awk -v h="$ph" -F: 'BEGIN{OFS=":"} $1=="root"{$2=h} {print}' \
				"$TARGET/etc/shadow" > "$TARGET/etc/shadow.rwrt" \
				&& mv "$TARGET/etc/shadow.rwrt" "$TARGET/etc/shadow" \
				|| warn "could not write the root password hash"
		else
			warn "could not hash the root password (openssl missing?)"
		fi
	fi

	# Enable the core services on boot by creating their rc.d symlinks directly (exactly
	# what OpenWrt's rc.common enable does: S<START>/K<STOP> from the init script). Most
	# services self-enable via their apk postinst, but the network service does not - so
	# without this the box boots with no network. Idempotent; a missing service is skipped.
	enable_svc() {
		_i="$TARGET/etc/init.d/$1"; [ -x "$_i" ] || return 0
		_s="$(sed -n 's/^START=\([0-9][0-9]*\).*/\1/p' "$_i" | head -1)"
		_k="$(sed -n 's/^STOP=\([0-9][0-9]*\).*/\1/p'  "$_i" | head -1)"
		mkdir -p "$TARGET/etc/rc.d"
		[ -n "$_s" ] && ln -sf "../init.d/$1" "$TARGET/etc/rc.d/S${_s}$1"
		[ -n "$_k" ] && ln -sf "../init.d/$1" "$TARGET/etc/rc.d/K${_k}$1"
		return 0   # a service with no STOP must not make this return non-zero under set -e
	}
	for svc in network firewall dnsmasq odhcpd dropbear sysntpd uhttpd; do enable_svc "$svc"; done

	# uci-default (runs once at first boot, AFTER config_generate creates /etc/config/system):
	#  - hostname: OpenWrt reads the uci hostname, and config_generate sets it to the board
	#    default, so set ours here rather than via /etc/hostname (which OpenWrt ignores).
	#  - ttylogin=1: OpenWrt hands out a passwordless root shell on the console by default
	#    (login.sh runs `login -f root` unless ttylogin=1), which would defeat the encrypted,
	#    auto-unlocking root - anyone at the console would get root after the TPM unlocks.
	mkdir -p "$TARGET/etc/uci-defaults"
	{
		printf 'uci -q set system.@system[0].hostname=%s\n' "'$CFG_hostname'"
		printf 'uci -q set system.@system[0].ttylogin=1\n'
		printf 'uci -q commit system\n'
	} > "$TARGET/etc/uci-defaults/99-rollingwrt-system"

	# Device apk feeds. base-files ships distfeeds.list (OpenWrt base + packages + target),
	# which we keep: the target feed carries libc/dropbear/grub2/... that we do not rebuild,
	# and our kernel + kmods out-rank OpenWrt's there by version, so the device installs
	# ours. We only ADD our own feed, via customfeeds.list (base-files never regenerates
	# that file, so it survives base-files upgrades).
	mkdir -p "$TARGET/etc/apk/repositories.d"
	{
		echo "$RWRT_REL/snapshot/packages.adb"
		for b in 1 2 3; do echo "$RWRT_REL/snapshot-kmods-$b/packages.adb"; done
	} > "$TARGET/etc/apk/repositories.d/customfeeds.list"
	# the install-time top-level list is redundant now; the .d/ lists drive apk on-device
	: > "$TARGET/etc/apk/repositories"

	# No runtime ESP mount: OpenWrt mounts via UCI (/etc/config/fstab), not /etc/fstab,
	# and by design the ESP stays unmounted while the system runs. rollingwrt-uki mounts
	# it read-write on demand (finding it by the rwrt-esp label) whenever the kernel
	# changes, then releases it. The initramfs gate finds the LUKS root via the cmdline.
}

# --------------------------------------------------------------- ceremony
# Write uki.conf and run the on-device assembler + SB + TPM, inside the target.
run_ceremony(){
	say "Boot assembly ($([ "$CFG_firmware" = efi ] && echo 'UKI + Secure Boot + TPM seal' || echo 'GRUB / legacy BIOS'))"
	kver="$(ls "$TARGET/lib/modules" 2>/dev/null | sort -V | tail -1)"
	[ -n "$kver" ] || die "no kernel installed under $TARGET/lib/modules; base package set is wrong"
	crypt=$([ "$CFG_encrypt" = yes ] && echo 1 || echo 0)
	# TPM auto-unlock is opt-in and only possible on UEFI with a TPM. When off, the disk
	# is still LUKS-encrypted but unlocks by passphrase at every boot; rollingwrt.tpm=0
	# tells the initramfs to skip the TPM path entirely.
	tpmseal=0
	if [ "$CFG_firmware" = efi ] && [ "$CFG_encrypt" = yes ] && [ "$CFG_tpm_unlock" = yes ] && has_tpm; then tpmseal=1; fi
	cmdline="rollingwrt.root=UUID=$ROOT_UUID rollingwrt.crypt=$crypt rollingwrt.tpm=$tpmseal rollingwrt.name=$RWRT_MAPPER $CFG_cmdline_extra"
	mkdir -p "$TARGET/etc/rollingwrt/keys"
	# machine TPM policy-signing key (the boot seal trusts this key, not a raw PCR). Only
	# when TPM auto-unlock is on; without the key rollingwrt-uki skips policy signing.
	if [ "$tpmseal" = 1 ]; then
		openssl genrsa -out "$TARGET/etc/rollingwrt/keys/tpm-policy.key" 2048 >/dev/null 2>&1
	fi
	cat > "$TARGET/etc/rollingwrt/uki.conf" <<-CONF
		FIRMWARE=$CFG_firmware
		KVER=$kver
		CMDLINE="$cmdline"
		ESP=/boot/efi
		ESP_DISK=$CFG_disk
		ESP_PART=1
		ESP_LABEL=$RWRT_ESP_LABEL
		TPM_SIGN_KEY=/etc/rollingwrt/keys/tpm-policy.key
		CRYPT=$crypt
	CONF
	for m in dev proc sys; do mkdir -p "$TARGET/$m"; mount --bind "/$m" "$TARGET/$m"; done
	if [ "$CFG_firmware" = efi ]; then
		# UEFI: bind efivars, create + stage the Secure Boot keys, build + sign the UKI
		# and install systemd-boot, then seal the LUKS key to the TPM under the signed
		# PCR-11 policy (so first boot unlocks with no passphrase). Passphrase on stdin.
		mount --bind /sys/firmware/efi/efivars "$TARGET/sys/firmware/efi/efivars" 2>/dev/null || true
		chroot "$TARGET" rollingwrt-secureboot enable || warn "secureboot enable reported a problem"
		chroot "$TARGET" rollingwrt-uki
		if [ "$tpmseal" = 1 ]; then
			printf '%s' "$CFG_passphrase" | chroot "$TARGET" rollingwrt-tpm-enroll "$CFG_root" || warn "TPM enroll failed; passphrase unlock still works"
		fi
		umount "$TARGET/sys/firmware/efi/efivars" 2>/dev/null || true
	else
		# BIOS: no UKI, no Secure Boot, no TPM. rollingwrt-uki reads FIRMWARE=bios from
		# uki.conf and execs rollingwrt-grub-install: GRUB in the MBR, kernel + unlock
		# initramfs on the FAT ESP. Encryption, if chosen, is passphrase-only LUKS.
		chroot "$TARGET" rollingwrt-uki
	fi
	for m in sys proc dev; do umount "$TARGET/$m" 2>/dev/null || true; done
}

finish(){
	say "Done"
	sync
	umount "$TARGET/boot/efi" 2>/dev/null || true
	umount "$TARGET" 2>/dev/null || true
	[ "$CFG_encrypt" = yes ] && cryptsetup close "$RWRT_MAPPER" 2>/dev/null || true
	cat <<-DONE

	rollingWRT is installed on $CFG_disk.
	  hostname   : $CFG_hostname
	  firmware   : $([ "$CFG_firmware" = efi ] && echo 'UEFI (signed UKI + systemd-boot)' || echo 'legacy BIOS (GRUB)')
	  encryption : $([ "$CFG_encrypt" = yes ] && echo "LUKS2$([ "$CFG_firmware" = efi ] && [ "$CFG_tpm_unlock" = yes ] && has_tpm && echo ' + TPM auto-unlock' || echo ' (passphrase at every boot)')" || echo none)
	  reach it   : ssh root@<its-ip>$([ -n "$CFG_sshkey" ] && echo ' (your key)' )

	$( [ "$CFG_encrypt" = yes ] && [ "$CFG_firmware" = efi ] && [ "$CFG_tpm_unlock" = yes ] && has_tpm && printf '%s\n' "  KEEP YOUR RECOVERY PASSPHRASE. It is the fallback if the TPM or hardware changes." )
	$( [ "$CFG_encrypt" = yes ] && { [ "$CFG_firmware" = bios ] || [ "$CFG_tpm_unlock" != yes ] || ! has_tpm; } && printf '%s\n' "  KEEP YOUR PASSPHRASE. You enter it at every boot to unlock the disk." )
	$( [ "$CFG_firmware" = efi ] && { setup_mode || printf '%s\n' "  Secure Boot: enter firmware once, clear/erase the Secure Boot keys (Setup Mode); the next boot enrolls rollingWRT's keys automatically."; } )
	Remove the install medium and reboot.
	DONE
}

# ============================================================= ncurses UI
# A menu-driven front end (dialog) that fills the same CFG_* the text wizard does.
# Instead of a fixed list of questions, the user navigates a settings menu and
# toggles features on and off, then chooses Install. Falls back to the text wizard
# when dialog is absent or there is no terminal (a scripted/sourced install).
DIALOG="${DIALOG:-dialog}"
use_tui(){ [ -t 0 ] && [ -t 1 ] && command -v "$DIALOG" >/dev/null 2>&1; }
# dialog draws on stderr and returns the choice on the fd we route to stdout.
dlg(){ "$DIALOG" --backtitle "rollingWRT installer" --no-collapse "$@" 3>&1 1>&2 2>&3; }
onoff(){ [ "$(yn "${1:-no}")" = yes ] && echo on || echo off; }

tui_disk(){
	set --
	while read -r name size model; do
		[ -n "$name" ] || continue
		st=off; [ "/dev/$name" = "$CFG_disk" ] && st=on
		set -- "$@" "/dev/$name" "$size ${model:-}" "$st"
	done <<-EOF
	$(list_disks)
	EOF
	d=$(dlg --radiolist "Target disk:" 16 70 6 "$@") || return
	[ -n "$d" ] && CFG_disk="$d"
	if [ "$CFG_firmware" = bios ]; then
		m=$(dlg --default-item "$CFG_mode" --menu "How to use $CFG_disk:" 12 72 3 \
			auto         "Whole disk (erase all of it)" \
			auto-reserve "Whole disk, reserve free space at the end") || return
	else
		m=$(dlg --default-item "$CFG_mode" --menu "How to use $CFG_disk:" 14 72 4 \
			auto         "Whole disk (erase all of it)" \
			auto-reserve "Whole disk, reserve free space at the end" \
			freespace    "Use existing free space (keep other partitions)" \
			custom       "Custom (pick ESP + root partitions)") || return
	fi
	CFG_mode="$m"
	case "$CFG_mode" in
		auto-reserve) r=$(dlg --inputbox "Free space to leave at the end (e.g. 100G):" 8 60 "${CFG_reserve:-100G}") && CFG_reserve="$r";;
		custom) e=$(dlg --inputbox "Existing ESP partition (shared, not wiped):" 8 64 "$CFG_esp") && CFG_esp="$e"
			ro=$(dlg --inputbox "Root partition (ENCRYPTED + erased):" 8 64 "$CFG_root") && CFG_root="$ro";;
	esac
}

tui_passphrase(){
	while :; do
		p1=$(dlg --insecure --passwordbox "LUKS passphrase:" 8 60) || return 1
		p2=$(dlg --insecure --passwordbox "Repeat passphrase:" 8 60) || return 1
		if [ -n "$p1" ] && [ "$p1" = "$p2" ]; then CFG_passphrase="$p1"; return 0; fi
		dlg --msgbox "Passphrases did not match (or were empty). Try again." 7 55
	done
}

tui_encrypt(){
	cur=none; [ "$(yn "$CFG_encrypt")" = yes ] && { cur=luks; [ "$(yn "$CFG_tpm_unlock")" = yes ] && cur=tpm; }
	if [ "$CFG_firmware" = efi ] && has_tpm; then
		e=$(dlg --default-item "$cur" --menu "Root encryption:" 12 72 3 \
			none "No encryption" \
			luks "LUKS2 - enter passphrase at every boot" \
			tpm  "LUKS2 + TPM auto-unlock (passphrase kept as fallback)") || return
	else
		e=$(dlg --default-item "$cur" --menu "Root encryption:" 11 72 2 \
			none "No encryption" \
			luks "LUKS2 - enter passphrase at every boot") || return
	fi
	# commit the encryption choice only once a passphrase is actually entered, so cancelling
	# the passphrase box leaves the previous setting unchanged
	case "$e" in
		none) CFG_encrypt=no;  CFG_tpm_unlock=no;  CFG_passphrase="";;
		luks) if tui_passphrase; then CFG_encrypt=yes; CFG_tpm_unlock=no;  fi;;
		tpm)  if tui_passphrase; then CFG_encrypt=yes; CFG_tpm_unlock=yes; fi;;
	esac
}

tui_features(){
	# LuCI is always installed, so it is not listed here - only the optional roles are.
	sel=$(dlg --separate-output --checklist "Features (space toggles, Enter confirms):" 13 70 4 \
		virt  "Virtualization: Incus containers + KVM/QEMU VMs" "$(onoff "$CFG_virt")" \
		zfs   "ZFS storage pools"                               "$(onoff "$CFG_zfs")" \
		samba "File sharing (Samba / SMB)"                      "$(onoff "$CFG_samba")") || return
	CFG_virt=no; CFG_zfs=no; CFG_samba=no
	for t in $sel; do case "$t" in
		virt) CFG_virt=yes;; zfs) CFG_zfs=yes;; samba) CFG_samba=yes;;
	esac; done
}

tui_host(){ h=$(dlg --inputbox "Hostname:" 8 50 "$CFG_hostname") && CFG_hostname="${h:-rollingwrt}"; }
tui_extra(){ e=$(dlg --inputbox "Extra packages to install (space-separated, blank for none):" 8 72 "$CFG_extra_pkgs") && CFG_extra_pkgs="$e"; }

tui_access(){
	# an SSH key and a root password are independent; set either, both, or (for the
	# password) neither. At least one is required, enforced at Install.
	while :; do
		ks="not set"; [ -n "$CFG_sshkey" ] && ks="set ($(printf '%s' "$CFG_sshkey" | grep -c .) key(s))"
		ps="not set"; [ -n "$CFG_password" ] && ps="set"
		a=$(dlg --cancel-label Back --menu "Admin access (set an SSH key, a root password, or both):" 12 68 3 \
			key  "SSH key ......... $ks" \
			pass "Root password ... $ps" \
			back "<< Back to the main menu") || return
		case "$a" in
			back) return;;
			key)
				k=$(dlg --inputbox "SSH key: github:USER, gitlab:USER, @file, or paste a key.\nBlank clears it." 10 72 "") || continue
				if [ -n "$k" ]; then
					resolve_sshkey "$k"
					if [ -n "$REPLY" ]; then CFG_sshkey="$REPLY"
						dlg --msgbox "Fetched $(printf '%s' "$CFG_sshkey" | grep -c .) key(s)." 6 42
					else dlg --msgbox "Could not fetch a key for: $k" 6 60; fi
				else CFG_sshkey=""; fi
				;;
			pass)
				while :; do
					p1=$(dlg --insecure --passwordbox "Root password (blank clears it):" 8 60) || break
					if [ -z "$p1" ]; then CFG_password=""; break; fi
					p2=$(dlg --insecure --passwordbox "Repeat password:" 8 60) || break
					if [ "$p1" = "$p2" ]; then CFG_password="$p1"; break; fi
					dlg --msgbox "Passwords did not match." 7 50
				done
				;;
		esac
	done
}

tui_advanced(){
	if dlg --yesno "Enable serial console (console=ttyS0,115200)?\nOnly for headless / serial hardware." 8 62; then
		case " $CFG_cmdline_extra " in
			*" console=ttyS0"*) : ;;
			*) CFG_cmdline_extra="${CFG_cmdline_extra:+$CFG_cmdline_extra }console=ttyS0,115200 console=tty0";;
		esac
	fi
	c=$(dlg --inputbox "Extra kernel command-line args to append:" 8 72 "$CFG_cmdline_extra") && CFG_cmdline_extra="$c"
}

tui_summary(){
	enc=none; [ "$(yn "$CFG_encrypt")" = yes ] && { enc=LUKS2; [ "$(yn "$CFG_tpm_unlock")" = yes ] && has_tpm && [ "$CFG_firmware" = efi ] && enc="LUKS2 + TPM"; }
	feat=""; for f in virt:Incus zfs:ZFS samba:Samba; do
		eval "v=\$CFG_${f%%:*}"; [ "$(yn "$v")" = yes ] && feat="$feat ${f#*:}"; done
	[ -n "$feat" ] || feat=" none"
	acc=""; [ -n "$CFG_sshkey" ] && acc="SSH key"; [ -n "$CFG_password" ] && acc="${acc:+$acc + }root password"; [ -n "$acc" ] || acc="none"
	dlg --yesno "Ready to install rollingWRT:

  Disk       : $CFG_disk ($CFG_mode)
  Firmware   : $CFG_firmware
  Encryption : $enc
  Features   :$feat
  Hostname   : $CFG_hostname
  Access     : $acc

This ERASES data on the disk per the mode above. Proceed?" 18 68
}

wizard_tui(){
	# Dialog returns non-zero whenever the user cancels a box; that is normal navigation
	# in this menu, NOT a fatal error, so relax `set -e` for the interactive part and put
	# it back before the install stages (which rely on strict error handling) run. Without
	# this, cancelling any sub-dialog would abort the whole installer.
	set +e
	CFG_profile=""   # the menu sets the toggles directly
	[ -n "$CFG_disk" ] && [ -b "$CFG_disk" ] || CFG_disk="/dev/$(list_disks | awk 'NR==1{print $1}')"
	choice=disk
	while :; do
		enc=none; [ "$(yn "$CFG_encrypt")" = yes ] && { enc=LUKS; [ "$(yn "$CFG_tpm_unlock")" = yes ] && enc=LUKS+TPM; }
		feat=""; for f in virt zfs samba; do eval "v=\$CFG_$f"; [ "$(yn "$v")" = yes ] && feat="$feat $f"; done
		[ -n "$feat" ] || feat=" none"
		acc=""; [ -n "$CFG_sshkey" ] && acc="ssh key"; [ -n "$CFG_password" ] && acc="${acc:+$acc + }password"; [ -n "$acc" ] || acc="none (required)"
		choice=$(dlg --cancel-label Quit --default-item "$choice" --menu "Configure the install, then choose Install. (Cancel/Esc on a sub-screen returns here.)" 19 76 10 \
			disk     "Disk .......... $CFG_disk ($CFG_mode)" \
			encrypt  "Encryption .... $enc" \
			features "Features ......$feat" \
			hostname "Hostname ...... $CFG_hostname" \
			access   "Admin access .. $acc" \
			extra    "Extra pkgs .... ${CFG_extra_pkgs:-none}" \
			advanced "Advanced ...... serial console / kernel args" \
			install  "  >>>  Install  <<<")
		if [ $? -ne 0 ]; then   # Quit/Esc on the main menu: confirm before leaving
			dlg --yesno "Quit the installer?\n\nNothing has been written to the disk yet." 8 56 && { clear 2>/dev/null || true; die "installation cancelled"; }
			continue
		fi
		case "$choice" in
			disk)     tui_disk;;
			encrypt)  tui_encrypt;;
			features) tui_features;;
			hostname) tui_host;;
			access)   tui_access;;
			extra)    tui_extra;;
			advanced) tui_advanced;;
			install)
				[ -b "$CFG_disk" ] || { dlg --msgbox "Pick a valid target disk first." 6 50; continue; }
				if [ "$(yn "$CFG_encrypt")" = yes ] && [ -z "$CFG_passphrase" ]; then
					dlg --msgbox "Set a LUKS passphrase in the Encryption menu." 6 55; continue; fi
				[ -n "$CFG_sshkey" ] || [ -n "$CFG_password" ] || {
					dlg --msgbox "Set an SSH key or a root password in Admin access." 6 60; continue; }
				if tui_summary; then set -e; clear 2>/dev/null || true; return 0; fi;;
		esac
	done
}

# ------------------------------------------------------------------- driver
main(){
	[ "$(id -u)" = 0 ] || die "run as root"
	preflight
	if use_tui; then
		wizard_tui           # the menu also does the final confirm
	else
		wizard
		review_cmdline
		confirm_destructive
	fi
	partition
	setup_target
	deploy_apk
	configure_system
	run_ceremony
	finish
}

# Only run when executed, not when sourced (image builders / tests source it).
case "${0##*/}" in rollingwrt-install) main "$@";; esac
